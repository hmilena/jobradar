# .env.local — copie este arquivo para .env.local e preencha os valores
# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# SSR inside Docker must reach the API container via the service name
NEXT_PUBLIC_API_URL_SERVER=http://api:8000
# Client-side fetches (browser) should hit the API exposed on your machine
NEXT_PUBLIC_API_URL_BROWSER=http://localhost:8000
