# Banco de dados (Supabase ou PostgreSQL local)
DATABASE_URL=postgresql://jobrador:jobrador@localhost:5432/jobrador

# API Anthropic (classificador de vagas)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude para classify_job (opcional — default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ITJobs API (fonte itjobs no scraper — https://www.itjobs.pt/api)
ITJOBS_API_KEY=

# Frontend (Next.js): copiar frontend/.env.local.example → frontend/.env.local
